# ---------------------------------------------------------------------------
# Copy this file to .env and fill in real values.
# .env is git-ignored. NEVER commit real secrets.
# ---------------------------------------------------------------------------

# Settings module: dev or prod
DJANGO_SETTINGS_MODULE=config.settings.development

# ---------------------------------------------------------------------------
# Core (required in every environment)
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=replace-me-with-a-50-character-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Separate signing key for JWT. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_JWT_SIGNING_KEY=replace-me-with-another-random-string

# Field-level encryption key for disciplinary records (Phase 7).
# CRITICAL: keep this SEPARATE from DJANGO_SECRET_KEY and back it up
# securely offline. Rotating SECRET_KEY is routine; this key must NEVER
# change without a re-encryption migration. If this key is lost, every
# encrypted disciplinary note becomes permanently unrecoverable.
DJANGO_FIELD_ENCRYPTION_KEY=replace-me-with-a-distinct-random-string

# ---------------------------------------------------------------------------
# Database (production only)
# ---------------------------------------------------------------------------
DJANGO_DB_NAME=kuppetmsa
DJANGO_DB_USER=kuppet
DJANGO_DB_PASSWORD=
DJANGO_DB_HOST=localhost
DJANGO_DB_PORT=5432
DJANGO_DB_SSLMODE=prefer

# ---------------------------------------------------------------------------
# Email (production)
# ---------------------------------------------------------------------------
DJANGO_DEFAULT_FROM_EMAIL=noreply@kuppetmombasa.co.ke
DJANGO_EMAIL_HOST=mail.skymesh.co.ke
DJANGO_EMAIL_PORT=587
DJANGO_EMAIL_HOST_USER=noreply@kuppetmombasa.co.ke
DJANGO_EMAIL_HOST_PASSWORD=
DJANGO_EMAIL_USE_TLS=True

# ---------------------------------------------------------------------------
# CORS / CSRF (production)
# ---------------------------------------------------------------------------
DJANGO_CORS_ORIGINS=https://kuppetmombasa.co.ke,https://www.kuppetmombasa.co.ke
DJANGO_CSRF_TRUSTED_ORIGINS=https://kuppetmombasa.co.ke,https://www.kuppetmombasa.co.ke

# ---------------------------------------------------------------------------
# Sentry (production, optional)
# ---------------------------------------------------------------------------
DJANGO_SENTRY_DSN=
DJANGO_SENTRY_ENV=production

# ---------------------------------------------------------------------------
# Media root
# ---------------------------------------------------------------------------
# LOCAL DEVELOPMENT: leave this line commented out. The code falls back
# to a project-local ./media/ directory which is writable and self-
# contained — no system paths, no sudo, no permission errors.
#
# PRODUCTION ONLY: uncomment and set to a path the service account owns
# and can write to. Convention here is /srv/<site>/media to match the
# /srv/kuppetmombasa working directory in docs/DEPLOYMENT.md §6 (the
# FHS-standard location for site-specific service data). Do NOT use
# /var/www/ — that's mixing conventions with the rest of the deploy.
# DJANGO_MEDIA_ROOT=/srv/kuppetmombasa/media

# ---------------------------------------------------------------------------
# Mpesa Daraja (added in phase 3 — leave blank for now)
# ---------------------------------------------------------------------------
MPESA_CONSUMER_KEY=
MPESA_CONSUMER_SECRET=
MPESA_PAYBILL=
MPESA_PASSKEY=
MPESA_CALLBACK_URL=https://kuppetmombasa.co.ke/api/v1/mpesa/callback/
MPESA_VALIDATION_URL=https://kuppetmombasa.co.ke/api/v1/mpesa/validate/
MPESA_CONFIRMATION_URL=https://kuppetmombasa.co.ke/api/v1/mpesa/confirm/
MPESA_ENV=sandbox
